.DS_Store
**/.DS_Store
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# =============================================================================
# Rust / Cargo
# =============================================================================
/target/
apps/agent-gui/src-tauri/target/

# Compiled artifacts
**/*.rs.bk

# Cargo.lock is committed for binary/application projects
# (already tracked — do NOT add Cargo.lock here)

# =============================================================================
# Node.js / Frontend
# =============================================================================
node_modules/
apps/agent-gui/dist/
# we use pnpm
package-lock.json
crates/agent-mcp/tests/fixtures/node_modules/

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Project-specific generated / local
# =============================================================================
# local user config (sensitive — may contain API keys)
kairox.toml
/.kairox/config.toml
# unplugin-auto-import / unplugin-vue-components generated artifacts
apps/agent-gui/src/auto-imports.d.ts
apps/agent-gui/src/components.d.ts
# Tauri auto-generated code
apps/agent-gui/src-tauri/gen/
.superpowers/
.worktrees/

# =============================================================================
# Database (SQLite)
# =============================================================================
*.db
*.db-shm
*.db-wal

# =============================================================================
# Testing artifacts
# =============================================================================
playwright-report/
apps/agent-gui/test-results/
test-results/
# tauri-pilot runner outputs (created by scripts/run-pilot-tests.sh)
/pilot-results/
/tauri-pilot-failures/

# =============================================================================
# Audit-driven UI/UX work
# =============================================================================
/audit-runs/
# Test coverage reports (vitest, c8, istanbul, cargo-tarpaulin, etc.)
coverage/
**/coverage/

# =============================================================================
# Build / Compilation cache
# =============================================================================
# TypeScript incremental build info
*.tsbuildinfo

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
