# Kairox configuration — copy to .env and fill in values
# These are read by agent-config via api_key_env fields in kairox.toml

# OpenAI-compatible API key (used by default profile)
OPENAI_API_KEY=

# Anthropic API key (for Claude models)
ANTHROPIC_API_KEY=

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434
