{
  "name": "kairox-tooling",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "format": "pnpm run format:web && pnpm run format:rust",
    "format:check": "pnpm run format:check:web && pnpm run format:check:rust",
    "format:check:rust": "cargo fmt --all --check",
    "format:check:web": "prettier --check \"{apps,crates,docs,fixtures}/**/*.{ts,tsx,js,jsx,vue,css,scss,sass,less,json,md}\" \"*.{json,md}\"",
    "format:rust": "cargo fmt --all",
    "format:web": "prettier --write \"{apps,crates,docs,fixtures}/**/*.{ts,tsx,js,jsx,vue,css,scss,sass,less,json,md}\" \"*.{json,md}\"",
    "lint": "pnpm run lint:web && pnpm run lint:rust",
    "lint:eslint": "eslint . --ext .ts,.tsx,.js,.jsx,.vue --ignore-pattern apps/agent-gui/src-tauri/gen/**",
    "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "lint:style": "stylelint \"apps/agent-gui/src/**/*.{vue,css,scss,sass,less}\"",
    "lint:web": "pnpm run lint:eslint && pnpm run lint:style",
    "prepare": "node scripts/prepare.cjs"
  },
  "lint-staged": {
    "*.rs": [
      "sh -c \"cargo fmt --all\""
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "apps/agent-gui/**/*.{ts,tsx,js,jsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "apps/agent-gui/src/**/*.{vue,css,scss,sass,less}": [
      "prettier --write",
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.9.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript-eslint": "^8.59.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
