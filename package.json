{
  "name": "kairox-tooling",
  "version": "0.19.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "pnpm run format:web && pnpm run format:rust",
    "format:check": "pnpm run format:check:web && pnpm run format:check:rust",
    "format:check:rust": "cargo fmt --all --check",
    "format:check:web": "npx oxfmt --check .",
    "format:rust": "cargo fmt --all",
    "format:web": "npx oxfmt --write .",
    "lint": "pnpm run lint:web && pnpm run lint:rust",
    "lint:oxlint": "npx oxlint",
    "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "lint:style": "stylelint \"apps/agent-gui/src/**/*.{vue,css,scss,sass,less}\"",
    "lint:web": "npx oxlint && npx stylelint \"apps/agent-gui/src/**/*.{vue,css,scss,sass,less}\"",
    "prepare": "node scripts/prepare.cjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.11.0",
    "stylelint-config-recommended-vue": "^1.6.1"
  },
  "lint-staged": {
    "*.rs": [
      "sh -c \"cargo fmt --all\""
    ],
    "*.{json,md}": [
      "oxfmt --write"
    ],
    "apps/agent-gui/*.{ts,tsx,js,jsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "apps/agent-gui/e2e/**/*.{ts,tsx,js,jsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "apps/agent-gui/src/!(generated)/**/*.{ts,tsx,js,jsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "apps/agent-gui/src/**/*.{vue,css,scss,sass,less}": [
      "oxfmt --write",
      "stylelint --fix"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0"
    },
    "shamefullyHoist": true,
    "strictPeerDependencies": false,
    "autoInstallPeers": true
  }
}
