{
  "name": "kairox-tooling",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "workspaces": [
    "apps/agent-gui"
  ],
  "scripts": {
    "format": "npm run format:web && npm run format:rust",
    "format:check": "npm run format:check:web && npm run format:check:rust",
    "format:check:rust": "cargo fmt --all --check",
    "format:check:web": "prettier --check \"{apps,crates,docs,fixtures}/**/*.{ts,tsx,js,jsx,vue,css,scss,sass,less,json,md}\" \"*.{json,md}\"",
    "format:rust": "cargo fmt --all",
    "format:web": "prettier --write \"{apps,crates,docs,fixtures}/**/*.{ts,tsx,js,jsx,vue,css,scss,sass,less,json,md}\" \"*.{json,md}\"",
    "lint": "npm run lint:web && npm run lint:rust",
    "lint:eslint": "eslint . --ext .ts,.tsx,.js,.jsx,.vue --ignore-pattern apps/agent-gui/src-tauri/gen/**",
    "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "lint:style": "stylelint \"apps/agent-gui/src/**/*.{vue,css,scss,sass,less}\"",
    "lint:web": "npm run lint:eslint && npm run lint:style",
    "prepare": "node scripts/prepare.cjs"
  },
  "lint-staged": {
    "*.rs": [
      "sh -c \"cargo fmt --all\""
    ],
    "*.{json,md}": [
      "prettier --write"
    ],
    "apps/agent-gui/**/*.{ts,tsx,js,jsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "apps/agent-gui/src/**/*.{vue,css,scss,sass,less}": [
      "prettier --write",
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "postcss-html": "^1.7.0",
    "prettier": "^3.5.3",
    "stylelint": "^17.9.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "typescript-eslint": "^8.31.1"
  }
}
