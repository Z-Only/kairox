{
  "name": "kairox-tooling",
  "version": "0.42.0",
  "private": true,
  "workspaces": [
    "apps/agent-gui"
  ],
  "type": "module",
  "scripts": {
    "format": "bun run format:web && bun run format:rust",
    "format:check": "bun run format:check:web && bun run format:check:rust",
    "format:check:rust": "cargo fmt --all --check",
    "format:check:web": "oxfmt --check .",
    "format:rust": "cargo fmt --all",
    "format:web": "oxfmt --write .",
    "lint": "bun run lint:web && bun run lint:rust && bun run lint:parity-matrix && bun run lint:no-inline-tests && bun run lint:release-docs",
    "lint:no-inline-tests": "bun scripts/check-no-inline-tests.mjs",
    "lint:oxlint": "oxlint",
    "lint:parity-matrix": "bun scripts/check-tui-gui-parity-matrix.mjs",
    "lint:release-docs": "node scripts/release-version-docs.mjs --check",
    "lint:rust": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "lint:style": "stylelint \"apps/agent-gui/src/**/*.{vue,css,scss,sass,less}\"",
    "lint:web": "oxlint && stylelint \"apps/agent-gui/src/**/*.{vue,css,scss,sass,less}\"",
    "dev:pilot": "bash scripts/dev-pilot.sh",
    "playwright:node-path": "node scripts/resolve-playwright-node-path.mjs",
    "site:build": "node scripts/ensure-site-release-cache.mjs && vitepress build site && node scripts/generate-llms-txt.mjs",
    "site:dev": "vitepress dev site --host 0.0.0.0",
    "site:preview": "vitepress preview site --host 0.0.0.0",
    "release-docs:check": "node scripts/release-version-docs.mjs --check",
    "release-docs:sync": "node scripts/release-version-docs.mjs --write",
    "test:scripts": "node --test scripts/*.test.mjs",
    "coverage": "bun run coverage:rust && bun run coverage:web",
    "coverage:rust": "bash scripts/run-rust-coverage.sh",
    "coverage:web": "cd apps/agent-gui && NODE_OPTIONS=\"--localstorage-file=/tmp/kairox-vitest-localstorage.json\" bun run test -- --coverage",
    "prepare": "bun scripts/prepare.cjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mermaid": "^11.16.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "overrides": {
    "glob": ">=10.5.0"
  },
  "lint-staged": {
    "*.rs": [
      "sh -c \"cargo fmt --all\""
    ],
    "*.{json,md}": [
      "oxfmt --write"
    ],
    "apps/agent-gui/*.{ts,tsx,js,jsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "apps/agent-gui/e2e/**/*.{ts,tsx,js,jsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "apps/agent-gui/src/!(generated)/**/*.{ts,tsx,js,jsx,vue}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "apps/agent-gui/src/**/*.{vue,css,scss,sass,less}": [
      "oxfmt --write",
      "stylelint --fix"
    ]
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "vue-demi"
  ]
}
