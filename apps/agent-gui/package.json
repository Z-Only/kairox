{
  "name": "agent-gui",
  "version": "0.42.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 0.0.0.0",
    "lint:style": "stylelint \"src/**/*.{vue,css,scss,sass,less}\"",
    "tauri": "node scripts/tauri-cli.mjs",
    "tauri:build": "tauri build",
    "tauri:dev": "bun run tauri -- dev",
    "test": "NODE_OPTIONS=\"--localstorage-file=/tmp/kairox-vitest-localstorage.json\" vitest run",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:e2e": "playwright test --workers 2",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^14.3.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.1.4",
    "@rolldown/binding-linux-x64-gnu": "1.1.4",
    "@rolldown/binding-win32-x64-msvc": "1.1.4"
  }
